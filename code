void handleLogin() {
  if (server.method() == HTTP_GET) {
    server.send(200, "text/html", LOGIN_PAGE);
    return;
  }
  if (server.method() == HTTP_POST) {
    String user = server.arg("username");
    String pass = server.arg("password");
    if (user == admin_user && pass == admin_pass) {
      session_token = String(random(0xffffffff), HEX) + String(millis(), HEX);
      session_expire = millis() + SESSION_TIMEOUT;
      server.sendHeader("Set-Cookie", "session=" + session_token + "; path=/");
      server.sendHeader("Location", "/", true);
      server.send(302, "text/plain", "");
    } else {
      server.sendHeader("Location", "/login?error=1", true);
      server.send(302, "text/plain", "");
    }
  }
}

void handleLogout() {
  session_token = "";
  session_expire = 0;
  server.sendHeader("Set-Cookie", "session=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/");
  server.sendHeader("Location", "/login", true);
  server.send(302, "text/plain", "");
}

void handleChangePassword() {
  if (!isAuthenticated()) return redirectToLogin();
  if (server.method() != HTTP_POST) {
    server.send(405, "text/plain", "Method Not Allowed");
    return;
  }
  if (!server.hasArg("plain")) {
    server.send(400, "text/plain", "No data");
    return;
  }
  JsonDocument doc;
  deserializeJson(doc, server.arg("plain"));
  String oldPass = doc["old_password"];
  String newPass = doc["new_password"];
  if (oldPass != admin_pass) {
    server.send(403, "text/plain", "Old password incorrect");
    return;
  }
  admin_pass = newPass;
  // 保存到配置文件
  JsonDocument cfg;
  File f = LittleFS.open("/config.json", "r");
  if (f) {
    deserializeJson(cfg, f);
    f.close();
  }
  cfg["admin_user"] = admin_user;
  cfg["admin_pass"] = admin_pass;
  f = LittleFS.open("/config.json", "w");
  serializeJson(cfg, f);
  f.close();
  server.send(200, "text/plain", "Password changed");
}

// ================= 受保护的页面和API =================
void handleRoot() {
  if (!isAuthenticated()) return redirectToLogin();
  server.send(200, "text/html", HTML_PAGE);
}

void handleApiConfig() {
  if (!isAuthenticated()) return redirectToLogin();
  JsonDocument doc;
  doc["wifi_ssid"] = config_ssid;
  doc["sim1_remark"] = sim1_remark;
  doc["sim2_remark"] = sim2_remark;
  doc["sim1_num"] = sim1_num;
  doc["sim2_num"] = sim2_num;
  doc["email_sms"] = email_enable_sms;
  doc["email_boot"] = email_enable_boot;
  doc["recipient"] = email_recipient;
  doc["webhook"] = wechat_url;
  doc["smtp_host"] = smtp_server;
  doc["smtp_port"] = smtp_port;
  doc["smtp_user"] = email_sender;
  doc["smtp_pass"] = email_auth;
  doc["admin_user"] = admin_user;
  String json;
  serializeJson(doc, json);
  server.send(200, "application/json", json);
}

void handleSave() {
  if (!isAuthenticated()) return redirectToLogin();
  if (!server.hasArg("plain")) {
    server.send(400, "text/plain", "No data");
    return;
  }
  JsonDocument doc;
  deserializeJson(doc, server.arg("plain"));
  saveConfig(doc);
  server.send(200, "text/plain", "Saved, restarting...");
  delay(1000);
  ESP.restart();
}

void handleSendSms() {
  if (!isAuthenticated()) return redirectToLogin();
  if (!server.hasArg("plain")) {
    server.send(400, "text/plain", "No data");
    return;
  }
  JsonDocument doc;
  deserializeJson(doc, server.arg("plain"));
  int slot = doc["sim"];
  String num = doc["num"].as<String>();
  String msg = doc["msg"].as<String>();
  bool ok = sendSMS(slot, num, msg);
  server.send(ok ? 200 : 500, "text/plain", ok ? "OK" : "Failed");
}

void handleLog() {
  if (!isAuthenticated()) return redirectToLogin();
  server.send(200, "text/plain", log_msg);
}

void handleScan() {
  if (!isAuthenticated()) return redirectToLogin();
  WiFi.mode(WIFI_AP_STA);
  int n = WiFi.scanNetworks();
  JsonDocument doc;
  JsonArray arr = doc.to<JsonArray>();
  for (int i = 0; i < n; i++) arr.add(WiFi.SSID(i));
  String json;
  serializeJson(doc, json);
  server.send(200, "application/json", json);
}

// ================= 配置存储 =================
void loadConfig() {
  if (!LittleFS.exists("/config.json")) return;
  File f = LittleFS.open("/config.json", "r");
  JsonDocument doc;
  deserializeJson(doc, f);
  if (doc.containsKey("wifi_ssid")) config_ssid = doc["wifi_ssid"].as<String>();
  if (doc.containsKey("wifi_pass")) config_pass = doc["wifi_pass"].as<String>();
  if (doc.containsKey("sim1_remark")) sim1_remark = doc["sim1_remark"].as<String>();
  if (doc.containsKey("sim2_remark")) sim2_remark = doc["sim2_remark"].as<String>();
  if (doc.containsKey("email_sms")) email_enable_sms = doc["email_sms"];
  if (doc.containsKey("email_boot")) email_enable_boot = doc["email_boot"];
  if (doc.containsKey("recipient")) email_recipient = doc["recipient"].as<String>();
  if (doc.containsKey("webhook")) wechat_url = doc["webhook"].as<String>();
  if (doc.containsKey("smtp_host")) smtp_server = doc["smtp_host"].as<String>();
  if (doc.containsKey("smtp_port")) smtp_port = doc["smtp_port"];
  if (doc.containsKey("smtp_user")) email_sender = doc["smtp_user"].as<String>();
  if (doc.containsKey("smtp_pass")) email_auth = doc["smtp_pass"].as<String>();
  if (doc.containsKey("admin_user")) admin_user = doc["admin_user"].as<String>();
  if (doc.containsKey("admin_pass")) admin_pass = doc["admin_pass"].as<String>();
  f.close();
}

void saveConfig(JsonDocument &doc) {
  JsonDocument full;
  File f = LittleFS.open("/config.json", "r");
  if (f) {
    deserializeJson(full, f);
    f.close();
  }
  for (JsonPair kv : doc.as<JsonObject>()) {
    full[kv.key()] = kv.value();
  }
  full["admin_user"] = admin_user;
  full["admin_pass"] = admin_pass;
  f = LittleFS.open("/config.json", "w");
  serializeJson(full, f);
  f.close();
  
  if (doc.containsKey("wifi_ssid")) config_ssid = doc["wifi_ssid"].as<String>();
