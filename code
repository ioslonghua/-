  if (doc.containsKey("sim1_remark")) sim1_remark = doc["sim1_remark"].as<String>();
  if (doc.containsKey("sim2_remark")) sim2_remark = doc["sim2_remark"].as<String>();
  if (doc.containsKey("email_sms")) email_enable_sms = doc["email_sms"];
  if (doc.containsKey("email_boot")) email_enable_boot = doc["email_boot"];
  if (doc.containsKey("recipient")) email_recipient = doc["recipient"].as<String>();
  if (doc.containsKey("webhook")) wechat_url = doc["webhook"].as<String>();
  if (doc.containsKey("smtp_host")) smtp_server = doc["smtp_host"].as<String>();
  if (doc.containsKey("smtp_port")) smtp_port = doc["smtp_port"];
