// ================= 设置 =================
void setup() {
  Serial.begin(115200);
  delay(1000);
  pinMode(LED_BUILTIN, OUTPUT);
  digitalWrite(LED_BUILTIN, HIGH);
  
  pinMode(MODEM1_EN, OUTPUT); digitalWrite(MODEM1_EN, LOW); delay(100); digitalWrite(MODEM1_EN, HIGH);
  pinMode(MODEM2_EN, OUTPUT); digitalWrite(MODEM2_EN, LOW); delay(100); digitalWrite(MODEM2_EN, HIGH);
  
  modem1.begin(115200, SERIAL_8N1, MODEM1_RX, MODEM1_TX);
  modem2.begin(115200, SERIAL_8N1, MODEM2_RX, MODEM2_TX);
  
  if (!LittleFS.begin(true)) Serial.println("LittleFS mount failed");
  loadConfig();
  
  initModem(modem1, 1);
  initModem(modem2, 2);
  
  sim1_num = getSimNumber(modem1);
  sim2_num = getSimNumber(modem2);
  
  forwardQueue = xQueueCreate(20, sizeof(ForwardMsg));
  xTaskCreate(sendEmailTask, "SMTP_Task", 8192, NULL, 1, &smtpTaskHandle);
  
  connectWiFi();
  
  esp_task_wdt_init(WDT_TIMEOUT, true);
  esp_task_wdt_add(NULL);
}

void loop() {
  if (inAPMode) dnsServer.processNextRequest();
  server.handleClient();
  checkModem(modem1, 1);
  checkModem(modem2, 2);
  esp_task_wdt_reset();
  delay(50);
}

// ================= 模块初始化 =================
void initModem(HardwareSerial &modem, int slot) {
  Serial.printf("Init modem %d...\n", slot);
  for (int i = 0; i < 5; i++) {
    modem.println("AT");
    delay(500);
    if (modem.available()) {
      String resp = modem.readStringUntil('\n');
      if (resp.indexOf("OK") >= 0) break;
    }
  }
  modem.println("AT+CMGF=0");      // PDU模式
  delay(100);
  modem.println("AT+CSCS=\"UCS2\""); // 支持中文
  delay(100);
  modem.println("AT+CNMI=2,1,0,0,0"); // 新短信提示
  delay(100);
  while(modem.available()) modem.read();
  Serial.printf("Modem %d ready\n", slot);
}

// ================= 短信接收 =================
void checkModem(HardwareSerial &modem, int slot) {
  if (!modem.available()) return;
  String line = modem.readStringUntil('\n');
  line.trim();
  if (line.length() == 0) return;
  if (line.startsWith("+CMTI:")) {
    int idx = line.substring(line.lastIndexOf(',') + 1).toInt();
    String pdu = readSmsPDU(modem, idx);
    if (pdu.length() > 0) {
      String sender, content, timestamp;
      if (decodePDU(pdu, sender, content, timestamp)) {
        enqueueForward(slot, sender, content, timestamp);
      }
      modem.printf("AT+CMGD=%d\r\n", idx);
      delay(200);
    }
  }
}

String readSmsPDU(HardwareSerial &modem, int index) {
  modem.printf("AT+CMGR=%d\r\n", index);
  String pdu = "";
  unsigned long start = millis();
  while (millis() - start < 3000) {
    if (modem.available()) {
      String line = modem.readStringUntil('\n');
      line.trim();
      if (line.startsWith("+CMGR:")) {
        while (!modem.available()) delay(10);
        pdu = modem.readStringUntil('\n');
        pdu.trim();
        break;
      }
    }
  }
  return pdu;
}

// ================= PDU解码（UCS2） =================
String ucs2ToUTF8(const String &hexStr) {
  String out = "";
  for (int i = 0; i < hexStr.length(); i += 4) {
    if (i + 3 >= hexStr.length()) break;
    unsigned int code = strtol(hexStr.substring(i, i+4).c_str(), NULL, 16);
    if (code <= 0x7F) out += (char)code;
    else if (code <= 0x7FF) {
      out += (char)(0xC0 | (code >> 6));
      out += (char)(0x80 | (code & 0x3F));
    } else {
      out += (char)(0xE0 | (code >> 12));
      out += (char)(0x80 | ((code >> 6) & 0x3F));
      out += (char)(0x80 | (code & 0x3F));
    }
  }
  return out;
}

bool decodePDU(const String &pdu, String &sender, String &content, String &timestamp) {
  if (pdu.length() < 20) return false;
  // 跳过服务中心长度，提取发送方号码（BCD）
  int idx = 2;
  int senderLen = strtol(pdu.substring(idx, idx+2).c_str(), NULL, 16);
  idx += 2;
  idx += 2; // 跳过TON/NPI
  String numberHex = pdu.substring(idx, idx + senderLen*2);
  sender = "";
  for (int i = 0; i < numberHex.length(); i+=2) {
    char high = numberHex[i+1];
    char low = numberHex[i];
    if (high == 'F') break;
    sender += high;
    if (low != 'F') sender += low;
  }
  // 跳过号码、PID、DCS
  idx += senderLen*2 + 2*2;
  // 时间戳7字节
  String timeHex = pdu.substring(idx, idx+14);
  String year = timeHex.substring(0,2);
  String month = timeHex.substring(2,4);
  String day = timeHex.substring(4,6);
  String hour = timeHex.substring(6,8);
  String minute = timeHex.substring(8,10);
  String second = timeHex.substring(10,12);
  timestamp = "20" + year + "-" + month + "-" + day + " " + hour + ":" + minute + ":" + second;
  idx += 14;
  int udl = strtol(pdu.substring(idx, idx+2).c_str(), NULL, 16);
  idx += 2;
  String userData = pdu.substring(idx, idx + udl*2);
  content = ucs2ToUTF8(userData);
  return true;
}

// ================= 主动发送短信（PDU模式，支持中文） =================
String strToUCS2Hex(const String &text) {
  String hex = "";
  for (int i = 0; i < text.length(); i++) {
    unsigned int code = (unsigned int)text.charAt(i);
    if (code < 0x80) {
      hex += "00";
      if (code < 0x10) hex += "0";
      hex += String(code, HEX);
    } else {
      // 多字节UTF-8简化处理，实际建议使用完整UTF8->UCS2转换
      hex += String(code, HEX);
    }
  }
  hex.toUpperCase();
  return hex;
}

bool sendSMS(int slot, const String &targetNum, const String &message) {
  HardwareSerial *modem = (slot == 1) ? &modem1 : &modem2;
  if (!modem) return false;
  
  // 将号码转为BCD
  String numClean = "";
  for (int i = 0; i < targetNum.length(); i++) {
    if (targetNum[i] >= '0' && targetNum[i] <= '9') numClean += targetNum[i];
  }
  if (numClean.length() % 2) numClean += "F";
  String bcdNum = "";
  for (int i = 0; i < numClean.length(); i += 2) {
    bcdNum += numClean[i+1];
    bcdNum += numClean[i];
  }
  
  // 构建PDU (基本提交格式)
  String pdu = "0011000B91" + bcdNum + "0008";
  String msgHex = strToUCS2Hex(message);
  pdu += msgHex;
  int pduLen = pdu.length() / 2;
  
  modem->println("AT+CMGF=0");
  delay(100);
  modem->printf("AT+CMGS=%d\r\n", pduLen);
  delay(500);
  modem->print(pdu);
  modem->write(0x1A);
  delay(3000);
  // 恢复接收设置
  modem->println("AT+CMGF=0");
  modem->println("AT+CSCS=\"UCS2\"");
  return true;
}

// ================= 转发队列与邮件任务 =================
void enqueueForward(int slot, const String &sender, const String &content, const String &timestamp) {
  ForwardMsg msg;
  msg.simSlot = slot;
  msg.sender = sender;
  msg.content = content;
  msg.timestamp = timestamp;
  xQueueSend(forwardQueue, &msg, 0);
}

void sendEmailTask(void *pvParameters) {
  ForwardMsg msg;
  for (;;) {
    if (xQueueReceive(forwardQueue, &msg, portMAX_DELAY) == pdTRUE) {
      String simDisplay = (msg.simSlot == 1) ? sim1_remark : sim2_remark;
      String simNum = (msg.simSlot == 1) ? sim1_num : sim2_num;
      if (simNum.length() > 0) simDisplay += "(" + simNum + ")";
      
      if (email_enable_sms && email_sender.length() > 0 && email_recipient.length() > 0) {
        smtp.debug(0);
        smtpConfig.server.host_name = smtp_server;
        smtpConfig.server.port = smtp_port;
        smtpConfig.login.email = email_sender;
        smtpConfig.login.password = email_auth;
        SMTP_Message message;
        message.sender.name = "SMS Forwarder";
        message.sender.email = email_sender;
        message.subject = "【" + simDisplay + "】新短信 from " + msg.sender;
        message.addRecipient("User", email_recipient);
        String html = "<h3>" + simDisplay + "</h3><p>" + msg.content + "</p><br>时间: " + msg.timestamp + "<br>发件人: " + msg.sender;
        message.html.content = html.c_str();
        MailClient.sendMail(&smtp, &message);
      }
      
      if (wechat_url.length() > 0) {
        sendWeChat(msg.content, msg.timestamp, msg.sender, simDisplay);
      }
      
      log_msg = "[" + simDisplay + "] " + msg.sender + ": " + msg.content + "\n" + log_msg;
      if (log_msg.length() > MAX_LOG_LEN) log_msg = log_msg.substring(0, MAX_LOG_LEN);
    }
  }
}

void sendWeChat(const String &text, const String &time, const String &sender, const String &simInfo) {
  HTTPClient http;
  http.begin(wechat_url);
  http.addHeader("Content-Type", "application/json");
  JsonDocument doc;
  doc["msgtype"] = "text";
  JsonObject textObj = doc.createNestedObject("text");
  String content = "【" + simInfo + "】\n" + text + "\n\n时间: " + time + "\n发件人: " + sender;
  textObj["content"] = content;
  String body;
  serializeJson(doc, body);
  http.POST(body);
  http.end();
}

// ================= 网络连接与Web服务器 =================
void connectWiFi() {
  if (config_ssid.length() == 0) {
    startAPMode();
    return;
  }
  WiFi.mode(WIFI_STA);
  WiFi.begin(config_ssid.c_str(), config_pass.c_str());
  int retry = 0;
  while (WiFi.status() != WL_CONNECTED && retry < 20) {
    delay(500);
    retry++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    inAPMode = false;
    setupWebServer();
    String ip = WiFi.localIP().toString();
    String bootMsg = "双卡转发器已启动\nIP: " + ip + "\n卡1: " + sim1_remark + "\n卡2: " + sim2_remark;
    if (email_enable_boot && email_recipient.length() > 0) {
      smtpConfig.server.host_name = smtp_server;
      smtpConfig.server.port = smtp_port;
      smtpConfig.login.email = email_sender;
      smtpConfig.login.password = email_auth;
      SMTP_Message msg;
      msg.sender.name = "Boot";
      msg.sender.email = email_sender;
      msg.subject = "系统启动";
      msg.addRecipient("User", email_recipient);
      msg.text.content = bootMsg.c_str();
      MailClient.sendMail(&smtp, &msg);
    }
    if (wechat_url.length() > 0) {
      sendWeChat(bootMsg, "", "系统", "启动");
    }
  } else {
    startAPMode();
  }
}

void setupWebServer() {
  server.on("/", handleRoot);
  server.on("/login", HTTP_ANY, handleLogin);
  server.on("/logout", handleLogout);
  server.on("/api/change_password", HTTP_POST, handleChangePassword);
  server.on("/log", handleLog);
  server.on("/api/config", HTTP_GET, handleApiConfig);
  server.on("/save", HTTP_POST, handleSave);
  server.on("/api/send_sms", HTTP_POST, handleSendSms);
  server.on("/scan", handleScan);
  server.begin();
}

void startAPMode() {
  inAPMode = true;
  WiFi.mode(WIFI_AP);
  WiFi.softAP("ESP32-SMS-Manager");
  dnsServer.start(53, "*", WiFi.softAPIP());
  setupWebServer();
}

// ================= 认证中间件 =================
bool isAuthenticated() {
  if (session_token.length() == 0) return false;
  if (millis() > session_expire) {
    session_token = "";
    return false;
  }
  String cookie = server.header("Cookie");
  int idx = cookie.indexOf("session=");
  if (idx == -1) return false;
  int end = cookie.indexOf(";", idx);
  String token = cookie.substring(idx + 8, end == -1 ? cookie.length() : end);
  return token == session_token;
}

void redirectToLogin() {
  server.sendHeader("Location", "/login", true);
  server.send(302, "text/plain", "");
}

