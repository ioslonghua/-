  if (doc.containsKey("smtp_pass")) email_auth = doc["smtp_pass"].as<String>();
}

String getSimNumber(HardwareSerial &modem) {
  modem.println("AT+CNUM");
  unsigned long start = millis();
  while (millis() - start < 2000) {
    if (modem.available()) {
      String line = modem.readStringUntil('\n');
      if (line.startsWith("+CNUM:")) {
        int q1 = line.indexOf('"');
        int q2 = line.indexOf('"', q1+1);
        int q3 = line.indexOf('"', q2+1);
        int q4 = line.indexOf('"', q3+1);
        if (q3>0 && q4>0) return line.substring(q3+1, q4);
      }
    }
  }
  return "";
}

