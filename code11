// ==================== 短信发送 ====================
bool sendSMS(HardwareSerial& modem, PDU& pdu, const char* phoneNumber, const char* message) {
  Serial.printf("发送短信 -> %s : %s\n", phoneNumber, message);
  pdu.setSCAnumber();
  int pduLen = pdu.encodePDU(phoneNumber, message);
  if (pduLen < 0) {
    Serial.printf("PDU编码失败: %d\n", pduLen);
    return false;
  }
  String pduStr = pdu.getSMS();
  Serial.println("PDU: " + pduStr);
  
  while (modem.available()) modem.read();
  modem.printf("AT+CMGS=%d\r\n", pduLen);
  unsigned long start = millis();
  bool gotPrompt = false;
  while (millis() - start < 5000) {
    if (modem.available()) {
      char c = modem.read();
      if (c == '>') { gotPrompt = true; break; }
    }
  }
  if (!gotPrompt) { Serial.println("未收到>"); return false; }
  
  modem.print(pduStr);
  modem.write(0x1A); // Ctrl+Z
  
  start = millis();
  String resp = "";
  while (millis() - start < 30000) {
    while (modem.available()) {
      char c = modem.read();
      resp += c;
      if (resp.indexOf("OK") >= 0) { Serial.println("发送成功"); return true; }
      if (resp.indexOf("ERROR") >= 0) { Serial.println("发送失败"); return false; }
    }
  }
  Serial.println("超时");
  return false;
}

// ==================== 管理员命令 ====================
bool isAdmin(const char* sender) {
  if (config.adminPhone.length() == 0) return false;
  String s = String(sender);
  String a = config.adminPhone;
  if (s.startsWith("+86")) s = s.substring(3);
  if (a.startsWith("+86")) a = a.substring(3);
  return s == a;
}

void processAdminCommand(const char* sender, const char* text) {
  String cmd = String(text);
  cmd.trim();
  Serial.println("处理管理员命令: " + cmd);
  
  if (cmd.startsWith("SMS:")) {
    int first = cmd.indexOf(':');
    int second = cmd.indexOf(':', first+1);
    if (second > first+1) {
      String target = cmd.substring(first+1, second);
      String msg = cmd.substring(second+1);
      target.trim(); msg.trim();
      // 默认使用卡1发送
      bool ok = sendSMS(SerialModem1, pdu1, target.c_str(), msg.c_str());
      String result = ok ? "成功" : "失败";
      sendEmailNotification("短信发送结果", "目标: " + target + "\n结果: " + result);
    }
  } else if (cmd.equals("RESET")) {
    sendEmailNotification("重启命令", "设备即将重启");
    delay(1000);
    ESP.restart();
  }
}

// ==================== 短信内容最终处理 ====================
void processSmsContent(int simSlot, const char* sender, const char* text, const char* timestamp) {
  Serial.printf("卡%d 收到短信: %s -> %s (%s)\n", simSlot, sender, text, timestamp);
  
  if (isAdmin(sender)) {
    processAdminCommand(sender, text);
    return;
  }
  
  String simRemark = (simSlot == 1) ? config.sim1Remark : config.sim2Remark;
  String subject = "短信(" + simRemark + ")来自" + String(sender);
  String body = "卡槽: " + simRemark + "\n发送者: " + sender + "\n时间: " + timestamp + "\n内容:\n" + text;
  sendEmailNotification(subject.c_str(), body.c_str());
}

// ==================== AT指令辅助 ====================
bool sendATandWaitOK(HardwareSerial& modem, const char* cmd, unsigned long timeout) {
  while (modem.available()) modem.read();
  modem.println(cmd);
  unsigned long start = millis();
  while (millis() - start < timeout) {
    if (modem.available()) {
      String resp = modem.readStringUntil('\n');
      if (resp.indexOf("OK") >= 0) return true;
      if (resp.indexOf("ERROR") >= 0) return false;
    }
  }
  return false;
}

String sendATCommand(HardwareSerial& modem, const char* cmd, unsigned long timeout) {
  while (modem.available()) modem.read();
  modem.println(cmd);
  unsigned long start = millis();
  String resp = "";
  while (millis() - start < timeout) {
    while (modem.available()) {
      char c = modem.read();
      resp += c;
      if (resp.indexOf("OK") >= 0 || resp.indexOf("ERROR") >= 0) {
        delay(50);
        while (modem.available()) resp += (char)modem.read();
        return resp;
      }
    }
  }
  return resp;
}

// ==================== 模组初始化 ====================
void initModem(HardwareSerial& modem, PDU& pdu, int slot) {
  Serial.printf("初始化卡%d模组...\n", slot);
  while (!sendATandWaitOK(modem, "AT", 1000)) {
    Serial.printf("卡%d AT无响应，重试...\n", slot);
    delay(1000);
  }
  sendATandWaitOK(modem, "AT+CMGF=0", 1000);      // PDU模式
  sendATandWaitOK(modem, "AT+CNMI=2,2,0,0,0", 1000); // 直接上报PDU
  Serial.printf("卡%d 初始化完成\n", slot);
}

// ==================== URC处理（带独立状态机） ====================
String readSerialLine(HardwareSerial& port) {
  static char buf[512];
  static int pos = 0;
  while (port.available()) {
    char c = port.read();
    if (c == '\n') {
      buf[pos] = 0;
      String line = String(buf);
      pos = 0;
      return line;
    } else if (c != '\r') {
      if (pos < 511) buf[pos++] = c;
    }
  }
  return "";
}

bool isHexString(const String& str) {
  if (str.length() == 0) return false;
  for (unsigned int i = 0; i < str.length(); i++) {
    char c = str.charAt(i);
    if (!((c >= '0' && c <= '9') || (c >= 'A' && c <= 'F') || (c >= 'a' && c <= 'f')))
      return false;
  }
  return true;
}

void checkModemURC(HardwareSerial& modem, PDU& pdu, ConcatSms* concatBuffer, int& state, int simSlot) {
  String line = readSerialLine(modem);
  if (line.length() == 0) return;
  Serial.printf("[卡%d] %s\n", simSlot, line.c_str());
  
  if (state == 0) {
    if (line.startsWith("+CMT:")) {
      state = 1;
    }
  } else if (state == 1) {
    if (line.length() == 0) return;
    if (isHexString(line)) {
      Serial.printf("PDU数据: %s\n", line.c_str());
      if (!pdu.decodePDU(line.c_str())) {
        Serial.println("PDU解析失败");
      } else {
        int* concatInfo = pdu.getConcatInfo();
        int ref = concatInfo[0], part = concatInfo[1], total = concatInfo[2];
        if (total > 1 && part > 0) {
          int slot = findOrCreateConcatSlot(concatBuffer, ref, pdu.getSender(), total);
          int idx = part - 1;
          if (idx >= 0 && idx < MAX_CONCAT_PARTS && !concatBuffer[slot].parts[idx].valid) {
            concatBuffer[slot].parts[idx].valid = true;
            concatBuffer[slot].parts[idx].text = String(pdu.getText());
            concatBuffer[slot].receivedParts++;
            if (concatBuffer[slot].receivedParts == 1)
              concatBuffer[slot].timestamp = String(pdu.getTimeStamp());
            if (concatBuffer[slot].receivedParts >= total) {
              String full = assembleConcatSms(concatBuffer, slot);
              processSmsContent(simSlot, concatBuffer[slot].sender.c_str(), full.c_str(), concatBuffer[slot].timestamp.c_str());
              clearConcatSlot(concatBuffer, slot);
            }
          }
        } else {
          processSmsContent(simSlot, pdu.getSender(), pdu.getText(), pdu.getTimeStamp());
        }
      }
      state = 0;
    } else {
      state = 0; // 非PDU数据，退出等待
    }
  }
}

// ==================== 工具箱辅助函数 ====================
String urlEncode(const String& str) {
  String encoded = "";
  for (unsigned int i = 0; i < str.length(); i++) {
    char c = str.charAt(i);
    if (c == ' ') encoded += '+';
    else if (isalnum(c)) encoded += c;
    else {
      char hex[4];
      sprintf(hex, "%%%02X", (unsigned char)c);
      encoded += hex;
    }
  }
  return encoded;
}

String jsonEscape(const String& str) {
  String out = "";
  for (unsigned int i = 0; i < str.length(); i++) {
    char c = str.charAt(i);
    if (c == '"') out += "\\\"";
    else if (c == '\\') out += "\\\\";
    else if (c == '\n') out += "\\n";
    else if (c == '\r') out += "\\r";
    else if (c == '\t') out += "\\t";
    else out += c;
  }
  return out;
}

String dingtalkSign(const String& secret, long timestamp) {
  String stringToSign = String(timestamp) + "\n" + secret;
  uint8_t hmacResult[32];
  mbedtls_md_context_t ctx;
  mbedtls_md_init(&ctx);
  mbedtls_md_setup(&ctx, mbedtls_md_info_from_type(MBEDTLS_MD_SHA256), 1);
  mbedtls_md_hmac_starts(&ctx, (const unsigned char*)secret.c_str(), secret.length());
  mbedtls_md_hmac_update(&ctx, (const unsigned char*)stringToSign.c_str(), stringToSign.length());
  mbedtls_md_hmac_finish(&ctx, hmacResult);
  mbedtls_md_free(&ctx);
  return urlEncode(base64::encode(hmacResult, 32));
}

