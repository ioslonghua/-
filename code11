// ==================== 长短信缓存管理 ====================
void initConcatBuffer(ConcatSms* buffer) {
  for (int i = 0; i < MAX_CONCAT_GROUPS; i++) {
    buffer[i].inUse = false;
    buffer[i].receivedParts = 0;
    for (int j = 0; j < MAX_CONCAT_PARTS; j++) {
      buffer[i].parts[j].valid = false;
      buffer[i].parts[j].text = "";
    }
  }
}

int findOrCreateConcatSlot(ConcatSms* buffer, int refNumber, const char* sender, int totalParts) {
  for (int i = 0; i < MAX_CONCAT_GROUPS; i++) {
    if (buffer[i].inUse && buffer[i].refNumber == refNumber && buffer[i].sender.equals(sender))
      return i;
  }
  for (int i = 0; i < MAX_CONCAT_GROUPS; i++) {
    if (!buffer[i].inUse) {
      buffer[i].inUse = true;
      buffer[i].refNumber = refNumber;
      buffer[i].sender = String(sender);
      buffer[i].totalParts = totalParts;
      buffer[i].receivedParts = 0;
      buffer[i].firstPartTime = millis();
      for (int j = 0; j < MAX_CONCAT_PARTS; j++) {
        buffer[i].parts[j].valid = false;
        buffer[i].parts[j].text = "";
      }
      return i;
    }
  }
  int oldest = 0;
  unsigned long oldestTime = buffer[0].firstPartTime;
  for (int i = 1; i < MAX_CONCAT_GROUPS; i++) {
    if (buffer[i].firstPartTime < oldestTime) {
      oldestTime = buffer[i].firstPartTime;
      oldest = i;
    }
  }
  buffer[oldest].inUse = true;
  buffer[oldest].refNumber = refNumber;
  buffer[oldest].sender = String(sender);
  buffer[oldest].totalParts = totalParts;
  buffer[oldest].receivedParts = 0;
  buffer[oldest].firstPartTime = millis();
  for (int j = 0; j < MAX_CONCAT_PARTS; j++) {
    buffer[oldest].parts[j].valid = false;
    buffer[oldest].parts[j].text = "";
  }
  return oldest;
}

String assembleConcatSms(ConcatSms* buffer, int slot) {
  String result = "";
  for (int i = 0; i < buffer[slot].totalParts; i++) {
    if (buffer[slot].parts[i].valid)
      result += buffer[slot].parts[i].text;
    else
      result += "[缺失分段" + String(i+1) + "]";
  }
  return result;
}

void clearConcatSlot(ConcatSms* buffer, int slot) {
  buffer[slot].inUse = false;
  buffer[slot].receivedParts = 0;
  buffer[slot].sender = "";
  buffer[slot].timestamp = "";
  for (int j = 0; j < MAX_CONCAT_PARTS; j++) {
    buffer[slot].parts[j].valid = false;
    buffer[slot].parts[j].text = "";
  }
}

void checkConcatTimeout(ConcatSms* buffer, int slotCount, int simSlot) {
  unsigned long now = millis();
  for (int i = 0; i < slotCount; i++) {
    if (buffer[i].inUse && (now - buffer[i].firstPartTime) >= CONCAT_TIMEOUT_MS) {
      Serial.printf("卡%d 长短信超时，强制转发\n", simSlot);
      String fullText = assembleConcatSms(buffer, i);
      processSmsContent(simSlot, buffer[i].sender.c_str(), fullText.c_str(), buffer[i].timestamp.c_str());
      clearConcatSlot(buffer, i);
    }
  }
}

