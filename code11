void handleSave() {
  if (!checkAuth()) return;
  config.sim1Remark = server.arg("sim1Remark");
  config.sim2Remark = server.arg("sim2Remark");
  config.smtpServer = server.arg("smtpServer");
  config.smtpPort = server.arg("smtpPort").toInt();
  config.smtpUser = server.arg("smtpUser");
  config.smtpPass = server.arg("smtpPass");
  config.smtpSendTo = server.arg("smtpSendTo");
  config.adminPhone = server.arg("adminPhone");
  config.webUser = server.arg("webUser");
  config.webPass = server.arg("webPass");
  saveConfig();
  server.send(200, "text/html", "<html><body>保存成功，3秒后重启<script>setTimeout(function(){location.href='/';},3000);</script></body></html>");
  delay(1000);
  ESP.restart();
}

void handleSendSms() {
  if (!checkAuth()) return;
  int slot = server.arg("simSlot").toInt();
  String phone = server.arg("phone");
  String content = server.arg("content");
  bool ok = false;
  if (slot == 1) ok = sendSMS(SerialModem1, pdu1, phone.c_str(), content.c_str());
  else ok = sendSMS(SerialModem2, pdu2, phone.c_str(), content.c_str());
  server.send(200, "text/html", ok ? "<html>发送成功</html>" : "<html>发送失败</html>");
}

void handlePing() {
  if (!checkAuth()) return;
  // 使用卡1进行Ping测试
  while (SerialModem1.available()) SerialModem1.read();
  SerialModem1.println("AT+CGACT=1,1");
  delay(2000);
  SerialModem1.println("AT+MPING=\"8.8.8.8\",30,1");
  unsigned long start = millis();
  String resp = "";
  while (millis() - start < 35000) {
    if (SerialModem1.available()) resp += (char)SerialModem1.read();
    if (resp.indexOf("+MPING:") >= 0) break;
  }
  SerialModem1.println("AT+CGACT=0,1");
  bool success = (resp.indexOf("+MPING:") >= 0 && (resp.indexOf("OK") >= 0 || resp.indexOf("1")>0));
  String result = success ? "Ping成功" : "Ping失败";
  server.send(200, "application/json", "{\"success\":" + String(success) + ",\"message\":\"" + result + "\"}");
}

void handleQuery() {
  if (!checkAuth()) return;
  String type = server.arg("type");
  String message = "";
  bool success = false;
  
  if (type == "ati") {
    String resp = sendATCommand(SerialModem1, "ATI", 3000);
    if (resp.indexOf("OK") >= 0) {
      success = true;
      message = "<pre>" + resp + "</pre>";
    } else message = "查询失败";
  }
  else if (type == "signal") {
    String resp = sendATCommand(SerialModem1, "AT+CESQ", 3000);
    if (resp.indexOf("+CESQ:") >= 0) {
      success = true;
      message = "<pre>" + resp + "</pre>";
    } else message = "查询失败";
  }
  else if (type == "siminfo") {
    String imsi = sendATCommand(SerialModem1, "AT+CIMI", 3000);
    String iccid = sendATCommand(SerialModem1, "AT+ICCID", 3000);
    String cnum = sendATCommand(SerialModem1, "AT+CNUM", 3000);
    success = true;
    message = "<pre>IMSI: " + imsi + "\nICCID: " + iccid + "\nCNUM: " + cnum + "</pre>";
  }
  else if (type == "network") {
    String cereg = sendATCommand(SerialModem1, "AT+CEREG?", 3000);
    String cops = sendATCommand(SerialModem1, "AT+COPS?", 3000);
    success = true;
    message = "<pre>注册状态: " + cereg + "\n运营商: " + cops + "</pre>";
  }
  else if (type == "wifi") {
    String info = "SSID: " + WiFi.SSID() + "\n";
    info += "IP: " + WiFi.localIP().toString() + "\n";
    info += "RSSI: " + String(WiFi.RSSI()) + " dBm\n";
    info += "MAC: " + WiFi.macAddress();
    success = true;
    message = "<pre>" + info + "</pre>";
  }
  else {
    message = "未知查询类型";
  }
  
  String json = "{\"success\":" + String(success) + ",\"message\":\"" + jsonEscape(message) + "\"}";
  server.send(200, "application/json", json);
}

void setupWebServer() {
  server.on("/", handleRoot);
  server.on("/save", HTTP_POST, handleSave);
  server.on("/tools", handleToolsPage);
  server.on("/sendsms", HTTP_POST, handleSendSms);
  server.on("/ping", HTTP_POST, handlePing);
  server.on("/query", handleQuery);
  server.begin();
  Serial.println("Web服务器已启动");
}

// ==================== 主程序 ====================
void setup() {
  Serial.begin(115200);
  SerialModem1.begin(115200, SERIAL_8N1, MODEM1_RXD, MODEM1_TXD);
  SerialModem2.begin(115200, SERIAL_8N1, MODEM2_RXD, MODEM2_TXD);
  
  loadConfig();
  initConcatBuffer(concatBuffer1);
  initConcatBuffer(concatBuffer2);
  
  WiFiMulti.addAP(WIFI_SSID, WIFI_PASS);
  Serial.println("连接WiFi");
  while (WiFiMulti.run() != WL_CONNECTED) delay(500);
  Serial.println("WiFi已连接 IP: " + WiFi.localIP().toString());
  
  setupWebServer();
  
  initModem(SerialModem1, pdu1, 1);
  initModem(SerialModem2, pdu2, 2);
  
  if (isConfigValid()) {
    sendEmailNotification("双卡短信转发器启动", "设备已启动\n地址: " + getDeviceUrl());
  }
}

